{
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/item", "destination": "/item.html" },
    { "source": "/guild/leaderboard", "destination": "/guild-leaderboard.html" },
    { "source": "/guild/event_history", "destination": "/guild-event-history.html" },
    { "source": "/guild/search", "destination": "/guild.html" },
    { "source": "/guild", "destination": "/guild.html" },
    { "source": "/territories", "destination": "/territories.html" },
    { "source": "/map", "destination": "/territories.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/api/item(.*)", "destination": "/api/item$1" },
    { "source": "/api/guild(.*)", "destination": "/api/guild$1" },
    { "source": "/api/user(.*)", "destination": "/api/user$1" },
    { "source": "/api/player(.*)", "destination": "/api/player$1" },
    { "source": "/api/discord/webhook-link", "destination": "/api/guild/events?discordAction=webhook-link" },
    { "source": "/api/discord/notify", "destination": "/api/guild/events?discordAction=notify" }
  ],
  "crons": [
    {
      "path": "/api/item/refresh",
      "schedule": "0 0 */3 * *"
    }
  ]
}
